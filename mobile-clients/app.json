{
  "expo": {
    "name": "AMT TRANS'IT",
    "slug": "amt-clients",
    "owner": "jeanaffas-organization",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A3553"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.amttransit.clients",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Pour enregistrer des messages vocaux dans le chat.",
        "NSPhotoLibraryUsageDescription": "Pour joindre des photos dans le chat.",
        "NSCameraUsageDescription": "Pour prendre des photos à joindre dans le chat."
      }
    },
    "android": {
      "package": "com.amttransit.clients",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A3553"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Pour joindre des photos dans le chat.",
          "cameraPermission": "Pour prendre des photos à joindre dans le chat."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Pour enregistrer des messages vocaux dans le chat."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "c0fb29ce-f8eb-4c3e-9ffb-f97d4329dee5"
      }
    }
  }
}
