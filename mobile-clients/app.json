{
  "expo": {
    "name": "AMT TRANS'IT",
    "slug": "amt-clients",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A3553"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.amttransit.clients"
    },
    "android": {
      "package": "com.amttransit.clients",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A3553"
      }
    },
    "extra": {
      "eas": { "projectId": "" }
    }
  }
}
