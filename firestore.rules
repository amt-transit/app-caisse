rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // =====================================================================
    // 1. FONCTIONS UTILITAIRES (Issues de vos anciennes règles)
    // =====================================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getUserRole() {
      return getUserData().role;
    }
    
    function isAdmin() {
      return isAuthenticated() && (getUserRole() in ['admin', 'super_admin']);
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'super_admin';
    }

    function hasGlobalAccess() {
      return isAuthenticated() && (isSuperAdmin() || getUserData().agency == 'all');
    }

    // Démarcheur (parrain/filleul) : identifié par custom claims posés par la
    // Cloud Function provisionDemarcheurAuth. N'A AUCUN accès staff (les règles
    // staff lisent le rôle dans /users, pas le token).
    function isDemarcheur() {
      return isAuthenticated() && request.auth.token.role == 'demarcheur';
    }
    function myDemarcheurId() {
      return request.auth.token.demarcheurId;
    }
    // Multi-route : un compte peut être rattaché à plusieurs fiches démarcheur
    // (une par route SaaS). Le claim `demarcheurIds` est un tableau plat alimenté
    // par provisionDemarcheurAuth (sinon : fallback sur l'ID legacy).
    function myDemarcheurIds() {
      return request.auth.token.demarcheurIds is list
        ? request.auth.token.demarcheurIds
        : [request.auth.token.demarcheurId];
    }
    function isOneOfMine(id) {
      return id in myDemarcheurIds();
    }

    // =====================================================================
    // 2. RÈGLES PAR RÔLE (Administration & Logs)
    // =====================================================================

    // Users : le super admin gère tout ; l'utilisateur ne peut modifier QUE sa propre
    // fiche, SANS pouvoir changer ses champs sensibles role/agency
    // (protection contre l'élévation de privilèges - auto-promotion en super_admin).
    match /users/{userId} {
      allow read: if isAuthenticated(); // Requis pour que les listes de chauffeurs s'affichent

      // Création / suppression d'un compte : réservé au super admin (panneau Gestion des agents)
      allow create, delete: if isSuperAdmin();

      // Mise à jour : super admin = tout ; sinon uniquement SA fiche et role/agency inchangés
      allow update: if isSuperAdmin()
                    || ( isAuthenticated()
                         && request.auth.uid == userId
                         && request.resource.data.get('role', '')   == resource.data.get('role', '')
                         && request.resource.data.get('agency', '') == resource.data.get('agency', '') );
    }
    
    // Audit Logs : Lecture pour les admins, écriture pour tous
    match /audit_logs/{document=**} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }

    // Rôles : définitions (menus + permissions "Actions") lisibles par TOUT
    // utilisateur connecté — auth-guard charge les permissions du rôle courant
    // au login, et sans ce droit un agent ne récupère jamais ses permissions
    // (bouton d'action masqué). Création / modification réservée aux admins
    // (panneau Rôles & Menus).
    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // =====================================================================
    // 3. RÈGLES HISTORIQUES (Paris/Abidjan classiques)
    // =====================================================================
    
    match /transactions/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    match /livraisons/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    match /expenses/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    match /bank_movements/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    // Demandes client (dépôt / récupération) émises depuis l'app AMT Clients.
    // Création/lecture côté client passent par des Cloud Functions (Admin SDK),
    // donc PAS besoin d'autoriser le client ici. Cette règle ouvre l'accès au
    // PERSONNEL (paris/abidjan + global) pour consulter et traiter les demandes.
    match /client_requests/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }

    // Notifications de l'app AMT Clients (cloche 🔔). Créées/lues par les Cloud
    // Functions (Admin SDK) côté client ; côté STAFF, lecture seule autorisée
    // pour diagnostic. Aucun accès en écriture direct n'est nécessaire ici.
    match /client_notifications/{document=**} {
      allow read: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }

    // Messagerie client (app AMT Clients). Le client crée/lit ses messages via
    // Cloud Functions (Admin SDK). Côté STAFF : lecture + écriture (répondre)
    // pour le personnel paris/abidjan + accès global.
    match /client_messages/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }

    // Fiches profil client (app AMT Clients) : nom/prénom/photo/langue. Le
    // client écrit via Cloud Function (Admin SDK) ; le STAFF lit (ex. afficher
    // le nom/photo dans la Messagerie clients).
    match /client_profiles/{document=**} {
      allow read: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }

    // Flotte automobile (Gestion Véhicule) : collections NON suffixées par route,
    // partagées par le personnel logistique paris/abidjan. Sans cette règle,
    // seuls les comptes globaux (super admin / agency 'all') pouvaient charger
    // la page -> un agent recevait permission-denied. L'affichage du bouton
    // d'enregistrement reste géré finement côté UI (permission manage_fleet).
    match /fleet_vehicles/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    match /fleet_transactions/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }

    // -------------------------------------------------------------------
    // 3-bis. VARIANTES AÉRIEN des collections historiques Paris/Abidjan
    // -------------------------------------------------------------------
    // Séparation totale Maritime/Aérien : en mode aérien, getCollectionName()
    // route vers des sous-tables suffixées `_aerien` (cf. agencies-config.js).
    // Mêmes droits que les tables de base. (Les routes SaaS sont déjà
    // couvertes par la règle 4 via le suffixe de route, ex. transactions_chine_aerien.)
    match /transactions_aerien/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    match /livraisons_aerien/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    match /livraisons_archives_aerien/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    match /expenses_aerien/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    match /clients_aerien/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    match /products_aerien/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    match /containers_aerien/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    match /appointments_aerien/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    match /quotes_aerien/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    match /quote_requests_aerien/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }
    match /boats_aerien/{document=**} {
      allow read, write: if isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']);
    }

    // =====================================================================
    // 3bis. ACCÈS DÉMARCHEUR (app mobile parrainage — LECTURE SEULE, strict)
    // =====================================================================
    // Additif : ne retire aucun accès staff (allow = OR entre règles).
    // Un démarcheur ne lit QUE son périmètre. Aucune écriture.

    match /demarcheurs/{id} {
      // Lecture :
      //  - démarcheur mobile : sa fiche + celles de ses filleuls directs ;
      //  - personnel staff (paris/abidjan + accès global) : peut lister les
      //    démarcheurs (badge "Parrain" sur la page Factures, gestion). On place
      //    la condition démarcheur EN PREMIER pour court-circuiter avant
      //    getUserData() (un démarcheur n'a pas de fiche /users).
      allow read: if (isDemarcheur() && (
                       id in myDemarcheurIds() ||
                       resource.data.parrainId in myDemarcheurIds()
                     ))
                  || (isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']));
      // Le démarcheur peut écrire UNIQUEMENT le token push sur SA fiche.
      // On verrouille à 3 champs précis pour empêcher toute escalade
      // (impossibilité de modifier solde / nom / parrainId / etc.).
      allow update: if isDemarcheur()
                    && id in myDemarcheurIds()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['pushToken', 'pushPlatform', 'pushTokenUpdatedAt']);
    }

    match /commissions/{id} {
      // Commissions directes ET bonus de parrainage : dans les deux cas
      // demarcheurId == le bénéficiaire (cf. creerCommissionParrainage).
      allow read: if isDemarcheur() && resource.data.demarcheurId in myDemarcheurIds();
    }

    match /retraits/{id} {
      allow read: if isDemarcheur() && resource.data.demarcheurId in myDemarcheurIds();
    }

    match /client_affiliations/{phone} {
      // Démarcheur : ses propres affiliations. Personnel staff : lecture pour le
      // badge "Parrain" sur la page Factures (condition démarcheur en premier).
      allow read: if (isDemarcheur() && resource.data.demarcheurId in myDemarcheurIds())
                  || (isAuthenticated() && (hasGlobalAccess() || getUserData().agency in ['paris', 'abidjan']));
    }

    match /retrait_demandes/{id} {
      // Demande de retrait créée par le démarcheur depuis l'app mobile.
      // Il crée UNIQUEMENT sa propre demande (montant numérique > 0, statut
      // figé à 'en_attente') et lit SES demandes. Aucune modification ni
      // suppression : le traitement/paiement reste côté staff (collection
      // retraits, inchangée). Le staff global lit/écrit via la règle 4.
      allow read: if isDemarcheur() && resource.data.demarcheurId in myDemarcheurIds();
      allow create: if isDemarcheur()
                    && request.resource.data.demarcheurId in myDemarcheurIds()
                    && request.resource.data.statut == 'en_attente'
                    && request.resource.data.montant is number
                    && request.resource.data.montant > 0;
    }

    // ----------------------------------------------------------------------
    // 3-ter. ACCÈS DÉMARCHEUR sur les collections SUFFIXÉES par route
    // ----------------------------------------------------------------------
    // Depuis mai 2026, les données du module Parrainage sont isolées par
    // route SaaS : demarcheurs_<route>, commissions_<route>, retraits_<route>,
    // client_affiliations_<route>, retrait_demandes_<route>. Ces règles
    // dupliquent la sécurité de la section 3bis pour matcher les noms
    // suffixés (Firestore Rules ne supporte pas de wildcard sur le nom de
    // collection dans le `match`, on utilise donc un match générique +
    // filtrage par regex dans la condition).
    match /{collectionName}/{id} {
      allow read: if isDemarcheur() && (
        // Sa propre fiche + celles de ses filleuls directs.
        (collectionName.matches('demarcheurs_.*') &&
          (id in myDemarcheurIds() || resource.data.parrainId in myDemarcheurIds())) ||
        // Ses commissions (directes + bonus parrainage).
        (collectionName.matches('commissions_.*') &&
          resource.data.demarcheurId in myDemarcheurIds()) ||
        // Ses factures (transactions) sur les routes SaaS.
        (collectionName.matches('transactions_.*') &&
          resource.data.demarcheurId in myDemarcheurIds()) ||
        // Ses livraisons (actives et archivées) sur les routes SaaS.
        (collectionName.matches('livraisons_.*') &&
          resource.data.demarcheurId in myDemarcheurIds()) ||
        // Ses retraits (paiements).
        (collectionName.matches('retraits_.*') &&
          resource.data.demarcheurId in myDemarcheurIds()) ||
        // Ses clients affiliés.
        (collectionName.matches('client_affiliations_.*') &&
          resource.data.demarcheurId in myDemarcheurIds()) ||
        // Ses demandes de retrait.
        (collectionName.matches('retrait_demandes_.*') &&
          resource.data.demarcheurId in myDemarcheurIds())
      );
      // Création d'une demande de retrait depuis l'app mobile (uniquement).
      allow create: if isDemarcheur()
                    && collectionName.matches('retrait_demandes_.*')
                    && request.resource.data.demarcheurId in myDemarcheurIds()
                    && request.resource.data.statut == 'en_attente'
                    && request.resource.data.montant is number
                    && request.resource.data.montant > 0;
      // Mise à jour du token push UNIQUEMENT sur SA fiche démarcheur (route
      // SaaS). 3 champs strictement autorisés ; tout autre champ refusé.
      allow update: if isDemarcheur()
                    && collectionName.matches('demarcheurs_.*')
                    && id in myDemarcheurIds()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['pushToken', 'pushPlatform', 'pushTokenUpdatedAt']);
    }

    match /parametres/commissions {
      // Lecture seule des taux (affichage), pas d'écriture.
      allow read: if isDemarcheur();
    }

    // ----------------------------------------------------------------------
    // 3-quater. ACCÈS DÉMARCHEUR sur SES factures et livraisons
    // ----------------------------------------------------------------------
    // L'app mobile affiche le détail complet de chaque facture (référence,
    // items, tracking colis, paiements) — uniquement les factures dont le
    // démarcheur est le parrain rattaché. La création stocke déjà
    // demarcheurId sur la transaction et la livraison (cf. nouvellefacture.js).
    // L'écriture reste réservée au staff (règles 3 et 4).
    match /transactions/{id} {
      allow read: if isDemarcheur() && resource.data.demarcheurId in myDemarcheurIds();
    }
    match /livraisons/{id} {
      allow read: if isDemarcheur() && resource.data.demarcheurId in myDemarcheurIds();
    }
    match /livraisons_archives/{id} {
      allow read: if isDemarcheur() && resource.data.demarcheurId in myDemarcheurIds();
    }

    // Tarifs d'expédition (CBM Chine, Aérien Normal/Express). Lecture par
    // TOUT utilisateur connecté (les agents de départ en ont besoin pour
    // calculer la facture) ; écriture réservée aux admins.
    match /parametres/tarifs {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // =====================================================================
    // 4. SÉCURITÉ DYNAMIQUE SaaS (Isolation Totale des Pays)
    // =====================================================================
    
    // Intercepte n'importe quelle autre collection (y compris transactions_chine_abidjan)
    match /{collectionName}/{document=**} {
      allow read, write: if isAuthenticated() && (
        
        // 4.1. L'utilisateur a le pass "Global"
        hasGlobalAccess() || 
        
        // 4.2. C'est une table dynamique qui appartient à SA route (ex: transactions_chine)
        collectionName.matches('.*_' + getUserData().agency + '.*') ||
        
        // 4.3. C'est l'agent de réception de la route (abidjan_chine a le droit de voir les tables de la chine)
        collectionName.matches('.*_' + getUserData().agency.replace('abidjan_', '') + '.*') ||
        
        // 4.4. Ce sont des collections partagées par tout le système logistique
        collectionName in [
          'clients', 'products', 'settings', 'agencies_config', 'containers', 
          'boats', 'prospects', 'appointments', 'agents', 'quote_requests', 
          'quotes', 'internal_chat', 'scan_logs', 'livraisons_archives'
        ]
      );
    }
    
  }
}
